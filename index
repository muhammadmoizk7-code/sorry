<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>For My Famoo Jaan ❤️</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Segoe UI', sans-serif;
}

body{
  background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
  color:white;
  overflow-x:hidden;
}

/* HEADER */
.header{
  position:sticky;
  top:0;
  background:rgba(0,0,0,0.5);
  backdrop-filter: blur(10px);
  text-align:center;
  padding:16px;
  font-size:16px;
  font-weight:600;
}

/* CHAT */
.chat-box{
  height:42vh;
  overflow-y:auto;
  padding:12px;
  display:flex;
  flex-direction:column;
  gap:12px;
}

/* BIGGER MESSAGES */
.msg{
  max-width:85%;
  padding:14px 16px;
  border-radius:18px;
  font-size:16px;   /* 👈 BIGGER TEXT FIX */
  line-height:1.6;
  animation:fadeIn 0.4s ease-in;
  word-wrap:break-word;
}

.sent{
  background:linear-gradient(135deg,#00c6ff,#0072ff);
  align-self:flex-end;
}

.received{
  background:rgba(255,255,255,0.12);
  align-self:flex-start;
}

/* typing */
.typing{
  font-size:13px;
  color:#ccc;
  font-style:italic;
}

/* LOVE SECTION */
.love{
  background:rgba(255,255,255,0.08);
  margin:14px;
  padding:22px;
  border-radius:20px;
  backdrop-filter: blur(12px);
  text-align:center;
}

.love h2{
  font-size:20px;
  color:#ff4d6d;
  margin-bottom:10px;
}

.love p{
  font-size:16px;
  margin:10px 0;
  line-height:1.7;
}

/* GALLERY */
.gallery{
  display:grid;
  grid-template-columns:1fr;
  gap:10px;
  margin-top:15px;
}

.gallery img{
  width:100%;
  height:220px;
  border-radius:16px;
  object-fit:cover;
}

/* FLOATING HEARTS */
.heart{
  position:fixed;
  bottom:-20px;
  font-size:20px;
  animation: floatUp 6s linear infinite;
  opacity:0.8;
}

@keyframes floatUp{
  0%{transform:translateY(0); opacity:1;}
  100%{transform:translateY(-110vh); opacity:0;}
}

@keyframes fadeIn{
  from{opacity:0; transform:translateY(10px);}
  to{opacity:1; transform:translateY(0);}
}

/* MOBILE */
@media(max-width:600px){
  .chat-box{height:40vh;}
  .msg{font-size:15px;}
  .love p{font-size:15px;}
}
</style>
</head>

<body>

<div class="header">💙 For My Famoo Jaan (Fatima) 💙</div>

<div class="chat-box" id="chat"></div>

<div class="love">
  <h2>💖 My Heart is Yours 💖</h2>

  <p>Fatima… my Famoo Jaan ❤️</p>
  <p>You are my peace, my smile, my everything 🥺</p>
  <p>I know I hurt you and I truly regret it 💔</p>
  <p>Please forgive me… I miss you so much 😔</p>

  <div class="gallery">
    <img src="pic1.jpg">
    <img src="pic2.jpg">
  </div>
</div>

<script>
const messages = [
  "Hey Fatima 🥺",
  "My Famoo Jaan ❤️",
  "I really miss you 💔",
  "I know you're upset...",
  "But I understand you 😔",
  "I am really sorry ❤️",
  "Please talk to me again 🥺"
];

let i = 0;
const chat = document.getElementById("chat");

function sendMsg(){

  if(i < messages.length){

    let typing = document.createElement("div");
    typing.className = "typing";
    typing.innerText = "typing...";
    chat.appendChild(typing);

    setTimeout(()=>{

      chat.removeChild(typing);

      let msg = document.createElement("div");
      msg.className = i % 2 === 0 ? "msg sent" : "msg received";
      msg.innerText = messages[i];

      chat.appendChild(msg);
      chat.scrollTop = chat.scrollHeight;

      i++;
      setTimeout(sendMsg,1100);

    },800);

  } else {
    createHearts();
  }
}

window.onload = sendMsg;

/* ❤️ LIVE HEARTS (AUTO CONTINUOUS) */
function createHearts(){
  setInterval(()=>{
    let heart = document.createElement("div");
    heart.className = "heart";
    heart.innerHTML = ["❤️","💖","💕","💗"][Math.floor(Math.random()*4)];
    heart.style.left = Math.random()*100 + "vw";
    heart.style.fontSize = (Math.random()*10+15)+"px";
    heart.style.animationDuration = (Math.random()*3+3)+"s";
    document.body.appendChild(heart);

    setTimeout(()=>heart.remove(),6000);
  },300);
}
</script>

</body>
</html>
