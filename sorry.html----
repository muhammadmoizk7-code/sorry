<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fammoo Jaan ❤️</title>

<style>
body {
  margin:0;
  font-family: Arial, sans-serif;
  background:#ece5dd;
}

/* HEADER */
.header {
  background:#075e54;
  color:white;
  padding:12px;
  font-size:16px;
  text-align:center;
}

/* CHAT */
.chat-box {
  height:50vh;
  overflow-y:auto;
  padding:10px;
}

.msg {
  max-width:80%;
  padding:10px;
  margin:8px;
  border-radius:10px;
  font-size:14px;
}

.sent {
  background:#dcf8c6;
  margin-left:auto;
}

.typing {
  font-size:12px;
  color:gray;
}

/* LOVE SECTION */
.love {
  background:white;
  padding:15px;
  text-align:center;
}

.love h2 {
  font-size:18px;
  color:#ff4d6d;
}

.love p {
  font-size:14px;
  line-height:1.5;
}

/* IMAGES */
.gallery {
  display:flex;
  flex-wrap:wrap;
  justify-content:center;
}

.gallery img {
  width:45%;
  margin:5px;
  border-radius:10px;
}

/* HEARTS */
.heart {
  position:fixed;
  color:red;
  animation: float 5s linear infinite;
}

@keyframes float {
  0% {transform: translateY(100vh);}
  100% {transform: translateY(-10vh);}
}
</style>
</head>

<body>

<div class="header">💚 Fammoo Jaan 💚</div>

<div class="chat-box" id="chat"></div>

<div class="love">
  <h2>💖 Sirf Tumhare Liye 💖</h2>

  <p>Fammoo Jaan... ❤️ tum meri life ka sabse special part ho 💕</p>

  <p>Mujhse galti ho gayi 💔 lekin main sach me sorry hoon 🥺</p>

  <p>Tumhari smile meri khushi hai 😊 aur tumhari narazgi meri punishment 😔</p>

  <p>Please maan jao... I really love you ❤️</p>

  <div class="gallery">
    <img src="pic1.jpg">
    <img src="pic2.jpg">
  </div>
</div>

<script>
const messages = [
  "Fammoo Jaan... 🥺",
  "please naraz mat ho...",
  "mujhse galti ho gayi 💔",
  "I am really sorry ❤️",
  "tum mere liye bohot important ho 💕",
  "I miss you 😔",
  "please baat kar lo... 🥺"
];

let i = 0;
const chat = document.getElementById("chat");

function sendMsg() {
  if(i < messages.length) {

    let typing = document.createElement("div");
    typing.className = "typing";
    typing.innerText = "typing...";
    chat.appendChild(typing);

    setTimeout(() => {
      chat.removeChild(typing);

      let msg = document.createElement("div");
      msg.className = "msg sent";
      msg.innerText = messages[i];
      chat.appendChild(msg);

      chat.scrollTop = chat.scrollHeight;
      i++;
      setTimeout(sendMsg, 1400);
    }, 800);

  } else {
    createHearts();
  }
}

window.onload = sendMsg;

function createHearts() {
  for (let i = 0; i < 25; i++) {
    let heart = document.createElement("div");
    heart.className = "heart";
    heart.innerHTML = "❤️";
    heart.style.left = Math.random()*100 + "vw";
    heart.style.animationDuration = (Math.random()*3+2)+"s";
    document.body.appendChild(heart);
  }
}
</script>

</body>
</html>
